/*
 * Device Tree file for Mono Gateway Development Kit — NXP SDK variant.
 *
 * This DTS overlays the mainline mono-gateway-dk.dts with NXP SDK-specific
 * bindings required by NXP's DPAA1 SDK drivers (sdk_fman, sdk_dpaa, fsl_usdpaa).
 *
 * Key differences from mainline:
 *   - BMan/QMan portals get 'cell-index' properties (required by SDK portal drivers)
 *   - SDK DPAA ethernet bus (fsl,dpaa with fsl,dpa-ethernet nodes)
 *   - FMan offline/host (OH) ports for SDK FMan PCD (policy classification)
 *   - Per-device dma-coherent instead of SoC-level (SDK DMA handling)
 *
 * Copyright 2025 Mono Technologies Inc.
 */

#include "mono-gateway-dk.dts"
#include "qoriq-qman-portals-sdk.dtsi"
#include "qoriq-bman-portals-sdk.dtsi"

/* SDK BMAN/QMAN memory pool descriptors need alloc-ranges for SDK drivers */
&bman_fbpr {
	compatible = "fsl,bman-fbpr";
	alloc-ranges = <0 0 0x10000 0>;
};
&qman_fqd {
	compatible = "fsl,qman-fqd";
	alloc-ranges = <0 0 0x10000 0>;
};
&qman_pfdr {
	compatible = "fsl,qman-pfdr";
	alloc-ranges = <0 0 0x10000 0>;
};

/*
 * SDK requires per-device dma-coherent instead of SoC-level.
 * Remove the SoC-level property, then add it to each device individually.
 */
&soc {
	/delete-property/ dma-coherent;

	/* SDK DPAA ethernet bus — binds NXP SDK fsl_dpa driver */
	#include "qoriq-dpaa-eth.dtsi"
	/* FMan offline/host ports — needed for SDK FMan PCD */
	#include "qoriq-fman3-0-6oh.dtsi"

	/* Delete PCIe IOMMU mappings (SDK doesn't use SMMU) */
	pcie@3400000 {
		/delete-property/ iommu-map;
	};
	pcie@3500000 {
		/delete-property/ iommu-map;
	};
	pcie@3600000 {
		/delete-property/ iommu-map;
	};

/* No SMMU on this board */
/delete-node/ iommu@9000000;

};

/*
 * SDK DPAA ethernet port configuration for Mono Gateway:
 *   ethernet@0 = enet0 (MAC1 - disabled, no PHY)
 *   ethernet@1 = enet1 (MAC2 - rightmost 1G, sgmii_phy2) ← eth2
 *   ethernet@2 = enet2 (MAC3 - disabled, no PHY)
 *   ethernet@3 = enet3 (MAC4 - disabled, no PHY)
 *   ethernet@4 = enet4 (MAC5 - leftmost 1G, sgmii_phy0) ← eth0
 *   ethernet@5 = enet5 (MAC6 - center 1G, sgmii_phy1) ← eth1
 *   ethernet@8 = enet6 (MAC9 - 10G left SFP) ← eth3
 *   (MAC10 added below as ethernet@9)
 */
&fsldpaa {
/* Disable unused MACs */
ethernet@0 {
status = "disabled";
};
ethernet@2 {
status = "disabled";
};
ethernet@3 {
status = "disabled";
};

/*
 * ethernet@8 (MAC9, 10G left SFP) — fix merged DTS conflict.
 * The mainline mono-gateway-dk.dts adds this node with
 * compatible = "fsl,dpa-ethernet-init" and static FQIDs (0x40c-0x40f).
 * qoriq-dpaa-eth.dtsi adds the same node with "fsl,dpa-ethernet".
 * DTC merges them: the node ends up with BOTH compatible strings
 * (last wins) AND the static fsl,qman-frame-queues-* properties.
 * The SDK dpa_fq_probe_mac() sees static FQIDs → allocates only
 * RX_DEFAULT, RX_ERROR, TX_CONF_MQ, TX_ERROR, TX_CONFIRM (8 FQs,
 * zero TX) instead of the full dynamic set (44 FQs with PCD + TX).
 * Fix: force SDK compatible and delete the static FQ properties.
 */
ethernet@8 {
compatible = "fsl,dpa-ethernet";
/delete-property/ fsl,qman-frame-queues-rx;
/delete-property/ fsl,qman-frame-queues-tx;
/delete-property/ fsl,bman-buffer-pools;
};

/* MAC10 — 10G right SFP. Same merge conflict fix + add node. */
ethernet@9 {
compatible = "fsl,dpa-ethernet";
fsl,fman-mac = <&enet7>;
dma-coherent;
/delete-property/ fsl,qman-frame-queues-rx;
/delete-property/ fsl,qman-frame-queues-tx;
/delete-property/ fsl,bman-buffer-pools;
};
};

/*
 * FMan: SDK driver needs compatible = "fsl,fman", "simple-bus"
 * Also remove 'managed' from 10G ports — SDK FMan handles link itself
 *
 * CRITICAL: Override port compatible strings from mainline format
 * ("fsl,fman-v3-port-rx/tx") to SDK format ("fsl,fman-port-{1g,10g}-{rx,tx}").
 * The SDK fm_port_driver match table does NOT match mainline v3 compat strings.
 * Without this, fm_port_probe() never runs, dev_set_drvdata() is never called,
 * and all fsl_mac probes fail with "dev_get_drvdata(port@XXXXX) failed" error -22.
 */
&fman0 {
compatible = "fsl,fman", "simple-bus";

/* 1G RX ports — mainline "fsl,fman-v3-port-rx" → SDK "fsl,fman-port-1g-rx" */
port@88000 { compatible = "fsl,fman-port-1g-rx"; };
port@89000 { compatible = "fsl,fman-port-1g-rx"; };
port@8a000 { compatible = "fsl,fman-port-1g-rx"; };
port@8b000 { compatible = "fsl,fman-port-1g-rx"; };
port@8c000 { compatible = "fsl,fman-port-1g-rx"; };
port@8d000 { compatible = "fsl,fman-port-1g-rx"; };

/* 10G RX ports — mainline "fsl,fman-v3-port-rx" → SDK "fsl,fman-port-10g-rx" */
port@90000 { compatible = "fsl,fman-port-10g-rx"; };
port@91000 { compatible = "fsl,fman-port-10g-rx"; };

/* 1G TX ports — mainline "fsl,fman-v3-port-tx" → SDK "fsl,fman-port-1g-tx" */
port@a8000 { compatible = "fsl,fman-port-1g-tx"; };
port@a9000 { compatible = "fsl,fman-port-1g-tx"; };
port@aa000 { compatible = "fsl,fman-port-1g-tx"; };
port@ab000 { compatible = "fsl,fman-port-1g-tx"; };
port@ac000 { compatible = "fsl,fman-port-1g-tx"; };
port@ad000 { compatible = "fsl,fman-port-1g-tx"; };

/* 10G TX ports — mainline "fsl,fman-v3-port-tx" → SDK "fsl,fman-port-10g-tx" */
port@b0000 { compatible = "fsl,fman-port-10g-tx"; };
port@b1000 { compatible = "fsl,fman-port-10g-tx"; };

/* 10GEC1 — SDK fsl_mac has no phylink/SFP support.
 * Delete mainline properties and add fixed-link so mac.c's
 * of_phy_register_fixed_link() succeeds. Without fixed-link,
 * mac_probe() hits "Wrong PHY information" → probe fails.
 * Kernel patch 4004 maps speed 10000 → SWMII_SPEED_1000
 * so swphy_decode_speed() in fixed_phy.c doesn't reject it.
 */
ethernet@f0000 {
/delete-property/ managed;
/delete-property/ sfp;
phy-connection-type = "xgmii";
fixed-link {
	speed = <10000>;
	full-duplex;
};
};

/* 10GEC2 — same treatment */
ethernet@f2000 {
/delete-property/ managed;
/delete-property/ sfp;
phy-connection-type = "xgmii";
fixed-link {
	speed = <10000>;
	full-duplex;
};
};
};

/*
 * Per-device dma-coherent for all SoC peripherals.
 * This replaces the deleted SoC-level '/delete-property/ dma-coherent'.
 */
&clockgen { dma-coherent; };
&scfg { dma-coherent; };
&crypto { dma-coherent; };
&dcfg { dma-coherent; };
&ifc { dma-coherent; };
&qspi { dma-coherent; };
&esdhc { dma-coherent; };
&ddr { dma-coherent; };
&tmu { dma-coherent; };
&qman { dma-coherent; };
&bman { dma-coherent; };
&bportals { dma-coherent; };
&qportals { dma-coherent; };
&dspi { dma-coherent; };
&i2c0 { dma-coherent; };
&i2c1 { dma-coherent; };
&i2c2 { dma-coherent; };
&i2c3 { dma-coherent; };
&duart0 { dma-coherent; };
&duart1 { dma-coherent; };
&duart2 { dma-coherent; };
&duart3 { dma-coherent; };
&gpio0 { dma-coherent; };
&gpio1 { dma-coherent; };
&gpio2 { dma-coherent; };
&gpio3 { dma-coherent; };
&lpuart0 { dma-coherent; };
&lpuart1 { dma-coherent; };
&lpuart2 { dma-coherent; };
&lpuart3 { dma-coherent; };
&lpuart4 { dma-coherent; };
&lpuart5 { dma-coherent; };
&ftm_alarm0 { dma-coherent; };
&wdog0 { dma-coherent; };
&edma0 { dma-coherent; };
&sata { dma-coherent; };
&qdma { dma-coherent; };
&msi1 { dma-coherent; };
&msi2 { dma-coherent; };
&msi3 { dma-coherent; };
&fman0 { dma-coherent; };
&ptp_timer0 { dma-coherent; };
&fsldpaa { dma-coherent; };
