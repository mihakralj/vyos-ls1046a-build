#!/bin/bash
# Replace upstream dpdk_plugin.so with DPAA1-enabled version.
# Must run AFTER vpp-plugin-dpdk deb is installed (hence chroot hook).
# NOTE: /tmp is cleaned by live-build before hooks run — use /opt instead.
STAGED=/opt/dpaa-dpdk-plugin.so
TARGET=/usr/lib/aarch64-linux-gnu/vpp_plugins/dpdk_plugin.so
if [ -f "$STAGED" ] && [ -f "$TARGET" ]; then
  cp "$STAGED" "$TARGET"
  rm -f "$STAGED"
  echo "### DPAA dpdk_plugin.so installed over upstream ($(stat -c%s $TARGET) bytes)"
else
  echo "WARNING: staged DPAA plugin or target not found"
  ls -la "$STAGED" "$TARGET" 2>&1 || true
fi

# Ensure binutils persists — VyOS live-build cleanup auto-removes it.
# apt-mark manual prevents autoremove from touching the package.
# We need nm/objdump/readelf on the target for DPAA plugin diagnostics.
apt-get install -y --no-install-recommends binutils 2>&1 | tail -3
apt-mark manual binutils 2>/dev/null || true
