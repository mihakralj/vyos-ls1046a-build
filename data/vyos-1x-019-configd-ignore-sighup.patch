diff --git a/src/services/vyos-configd b/src/services/vyos-configd
--- a/src/services/vyos-configd
+++ b/src/services/vyos-configd
@@ -358,6 +358,11 @@ if __name__ == '__main__':
 
     signal.signal(signal.SIGTERM, sig_handler)
