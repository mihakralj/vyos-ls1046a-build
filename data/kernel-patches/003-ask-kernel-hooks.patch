+++ b/net/netfilter/xt_qosconnmark.c
@@ -0,0 +1,171 @@
+/* xt_connmark - Netfilter module to operate on connection marks
+ *
+ * Copyright (C) 2002,2004 MARA Systems AB <http://www.marasystems.com>
+ * by Henrik Nordstrom <hno@marasystems.com>
