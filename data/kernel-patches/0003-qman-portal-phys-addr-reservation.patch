From: Beast <beast@mono-gateway.local>
Date: Wed, 26 Mar 2026 21:00:00 +0000
Subject: [PATCH 3/6] soc: fsl: qbman: QMan portal phys addr storage and
 reservation pool

Same pattern as the BMan portal patch: store physical addresses during
probe and maintain a free portal pool for userspace reservation.

QMan portals additionally carry a channel ID and pool mask, both
needed by DPDK for frame queue scheduling and stash configuration.

On LS1046A: 10 QMan portals, 4 CPUs → 6 available for DPDK.

Signed-off-by: Beast <beast@mono-gateway.local>
---
 drivers/soc/fsl/qbman/qman_portal.c | 55 ++++++++++++++++++++++++++++
 drivers/soc/fsl/qbman/qman_priv.h   | 12 ++++++
 2 files changed, 67 insertions(+)

diff --git a/drivers/soc/fsl/qbman/qman_priv.h b/drivers/soc/fsl/qbman/qman_priv.h
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/qman_priv.h
+++ b/drivers/soc/fsl/qbman/qman_priv.h
@@ -XXX,6 +XXX,12 @@
 struct qm_portal_config {
 	/* Portal addresses */
 	void *addr_virt_ce;
 	void __iomem *addr_virt_ci;
+	/* Physical addresses for userspace mmap (populated during probe) */
+	resource_size_t addr_phys_ce;
+	resource_size_t addr_phys_ci;
+	size_t size_ce;
+	size_t size_ci;
 	struct device *dev;
 	struct iommu_domain *iommu_domain;
 	/* Allow these to be joined in lists */
@@ -XXX,8 +XXX,14 @@
 	u16 channel;
 	u32 pools;
+	/* true if reserved for userspace (not affine to any CPU) */
+	bool reserved;
 };
 
+/* Portal reservation API for USDPAA mainline driver */
+int qman_portal_reserve(struct qm_portal_config **pcfg_out);
+void qman_portal_release_reserved(struct qm_portal_config *pcfg);
+
 void qman_init_cgr_all(void);
 
diff --git a/drivers/soc/fsl/qbman/qman_portal.c b/drivers/soc/fsl/qbman/qman_portal.c
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/qman_portal.c
+++ b/drivers/soc/fsl/qbman/qman_portal.c
@@ -XXX,6 +XXX,10 @@
 
 static DEFINE_SPINLOCK(qman_lock);
 
+/* Pool of portals available for userspace reservation */
+static LIST_HEAD(qman_free_portals);
+static DEFINE_SPINLOCK(qman_free_lock);
+
 static int qman_portal_probe(struct platform_device *pdev)
 {
 	struct device *dev = &pdev->dev;
@@ -XXX,11 +XXX,19 @@
 	pcfg->dev = dev;
 
 	addr_phys = platform_get_resource(pdev, IORESOURCE_MEM,
 					  DPAA_PORTAL_CE);
-	if (!addr_phys) {
+	if (!addr_phys) {
 		dev_err(dev, "Can't get %pOF property 'reg::CE'\n", node);
 		goto err_ioremap1;
 	}
+	pcfg->addr_phys_ce = addr_phys->start;
+	pcfg->size_ce = resource_size(addr_phys);
+
+	addr_phys = platform_get_resource(pdev, IORESOURCE_MEM,
+					  DPAA_PORTAL_CI);
+	if (!addr_phys) {
+		dev_err(dev, "Can't get %pOF property 'reg::CI'\n", node);
+		goto err_ioremap1;
+	}
+	pcfg->addr_phys_ci = addr_phys->start;
+	pcfg->size_ci = resource_size(addr_phys);
 
 	/* ... existing memremap/ioremap + channel read ... */
 
@@ -XXX,6 +XXX,16 @@
 	spin_lock(&qman_lock);
 	cpu = cpumask_first(&portal_available_cpus);
 	if (cpu >= nr_cpu_ids) {
+		/*
+		 * No CPU available for this portal — add to the free
+		 * portal pool for userspace reservation via USDPAA.
+		 * Channel and pools fields are already populated.
+		 */
+		pcfg->reserved = false;
+		spin_lock(&qman_free_lock);
+		list_add_tail(&pcfg->list, &qman_free_portals);
+		spin_unlock(&qman_free_lock);
 		spin_unlock(&qman_lock);
-		/* Portal not needed */
 		return 0;
 	}
@@ -XXX,6 +XXX,44 @@
 	return -ENXIO;
 }
 
+/**
+ * qman_portal_reserve - Reserve a QMan portal for userspace use
+ * @pcfg_out: pointer to receive the portal configuration
+ *
+ * Removes a portal from the free pool and marks it as reserved.
+ * The caller receives the portal's physical addresses, channel ID,
+ * IRQ, and pool mask for DPDK configuration.
+ *
+ * Returns 0 on success, -ENOENT if no free portals are available.
+ */
+int qman_portal_reserve(struct qm_portal_config **pcfg_out)
+{
+	struct qm_portal_config *pcfg;
+
+	spin_lock(&qman_free_lock);
+	if (list_empty(&qman_free_portals)) {
+		spin_unlock(&qman_free_lock);
+		return -ENOENT;
+	}
+	pcfg = list_first_entry(&qman_free_portals,
+				struct qm_portal_config, list);
+	list_del(&pcfg->list);
+	pcfg->reserved = true;
+	spin_unlock(&qman_free_lock);
+
+	/*
+	 * NOTE: Do NOT unmap kernel CE mapping here.
+	 * Same rationale as bman_portal_reserve() — see patch 0002.
+	 * Unmapping destabilizes vmalloc and crashes affine portals.
+	 * Reserved portals are never accessed by kernel code.
+	 */
+
+	*pcfg_out = pcfg;
+	return 0;
+}
+EXPORT_SYMBOL(qman_portal_reserve);
+
+/**
+ * qman_portal_release_reserved - Return a reserved QMan portal
+ * @pcfg: portal config previously obtained from qman_portal_reserve()
+ */
+void qman_portal_release_reserved(struct qm_portal_config *pcfg)
+{
+	spin_lock(&qman_free_lock);
+	pcfg->reserved = false;
+	list_add_tail(&pcfg->list, &qman_free_portals);
+	spin_unlock(&qman_free_lock);
+}
+EXPORT_SYMBOL(qman_portal_release_reserved);
+
 static const struct of_device_id qman_portal_ids[] = {
 	{
 		.compatible = "fsl,qman-portal",
-- 
