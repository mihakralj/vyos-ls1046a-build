From: Beast <beast@mono-gateway.local>
Date: Wed, 26 Mar 2026 21:00:00 +0000
Subject: [PATCH 2/6] soc: fsl: qbman: BMan portal phys addr storage and
 reservation pool

Store physical addresses of portal CE/CI regions during probe and
maintain a free list of portals not assigned to any CPU. On LS1046A
with 10 BMan portals and 4 CPUs, 6 portals are unaffined and available
for userspace reservation via the USDPAA driver.

Export bman_portal_reserve() and bman_portal_release_reserved() for
use by the fsl_usdpaa_mainline module.

Signed-off-by: Beast <beast@mono-gateway.local>
---
 drivers/soc/fsl/qbman/bman_portal.c | 55 ++++++++++++++++++++++++++++
 drivers/soc/fsl/qbman/bman_priv.h   | 12 ++++++
 2 files changed, 67 insertions(+)

diff --git a/drivers/soc/fsl/qbman/bman_priv.h b/drivers/soc/fsl/qbman/bman_priv.h
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/bman_priv.h
+++ b/drivers/soc/fsl/qbman/bman_priv.h
@@ -XXX,6 +XXX,12 @@
 struct bm_portal_config {
 	/* Portal addresses */
 	void *addr_virt_ce;
 	void __iomem *addr_virt_ci;
+	/* Physical addresses for userspace mmap (populated during probe) */
+	resource_size_t addr_phys_ce;
+	resource_size_t addr_phys_ci;
+	size_t size_ce;
+	size_t size_ci;
 	/* Allow these to be joined in lists */
 	struct list_head list;
 	struct device *dev;
@@ -XXX,8 +XXX,14 @@
 	/* portal interrupt line */
 	int irq;
+	/* true if reserved for userspace (not affine to any CPU) */
+	bool reserved;
 };
 
+/* Portal reservation API for USDPAA mainline driver */
+int bman_portal_reserve(struct bm_portal_config **pcfg_out);
+void bman_portal_release_reserved(struct bm_portal_config *pcfg);
+
 struct bman_portal *bman_create_affine_portal(
 			const struct bm_portal_config *config);
 
diff --git a/drivers/soc/fsl/qbman/bman_portal.c b/drivers/soc/fsl/qbman/bman_portal.c
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/bman_portal.c
+++ b/drivers/soc/fsl/qbman/bman_portal.c
@@ -XXX,6 +XXX,10 @@
 
 static DEFINE_SPINLOCK(bman_lock);
 
+/* Pool of portals available for userspace reservation */
+static LIST_HEAD(bman_free_portals);
+static DEFINE_SPINLOCK(bman_free_lock);
+
 static int bman_portal_probe(struct platform_device *pdev)
 {
 	struct device *dev = &pdev->dev;
@@ -XXX,11 +XXX,19 @@
 	pcfg->dev = dev;
 
 	addr_phys = platform_get_resource(pdev, IORESOURCE_MEM,
 					  DPAA_PORTAL_CE);
-	if (!addr_phys) {
+	if (!addr_phys) {
 		dev_err(dev, "Can't get %pOF property 'reg::CE'\n", node);
 		goto err_ioremap1;
 	}
+	pcfg->addr_phys_ce = addr_phys->start;
+	pcfg->size_ce = resource_size(addr_phys);
+
+	addr_phys = platform_get_resource(pdev, IORESOURCE_MEM,
+					  DPAA_PORTAL_CI);
+	if (!addr_phys) {
+		dev_err(dev, "Can't get %pOF property 'reg::CI'\n", node);
+		goto err_ioremap1;
+	}
+	pcfg->addr_phys_ci = addr_phys->start;
+	pcfg->size_ci = resource_size(addr_phys);
 
 	/* ... existing memremap/ioremap ... */
 
@@ -XXX,6 +XXX,16 @@
 	spin_lock(&bman_lock);
 	cpu = cpumask_first(&portal_available_cpus);
 	if (cpu >= nr_cpu_ids) {
+		/*
+		 * No CPU available for this portal — add to the free
+		 * portal pool for userspace reservation via USDPAA.
+		 */
+		pcfg->reserved = false;
+		spin_lock(&bman_free_lock);
+		list_add_tail(&pcfg->list, &bman_free_portals);
+		spin_unlock(&bman_free_lock);
 		spin_unlock(&bman_lock);
-		/* Portal not needed */
 		return 0;
 	}
@@ -XXX,6 +XXX,40 @@
 	return -ENXIO;
 }
 
+/**
+ * bman_portal_reserve - Reserve a BMan portal for userspace use
+ * @pcfg_out: pointer to receive the portal configuration
+ *
+ * Removes a portal from the free pool and marks it as reserved.
+ * The caller receives the portal's physical addresses for mmap.
+ *
+ * Returns 0 on success, -ENOENT if no free portals are available.
+ */
+int bman_portal_reserve(struct bm_portal_config **pcfg_out)
+{
+	struct bm_portal_config *pcfg;
+
+	spin_lock(&bman_free_lock);
+	if (list_empty(&bman_free_portals)) {
+		spin_unlock(&bman_free_lock);
+		return -ENOENT;
+	}
+	pcfg = list_first_entry(&bman_free_portals,
+				struct bm_portal_config, list);
+	list_del(&pcfg->list);
+	pcfg->reserved = true;
+	spin_unlock(&bman_free_lock);
+
+	/*
+	 * NOTE: Do NOT unmap kernel CE mapping here.
+	 *
+	 * The upstream kernel maps addr_virt_ce to CI physical address
+	 * (platform_get_resource overwrites CE ptr with CI before memremap).
+	 * Unmapping it destabilizes vmalloc bookkeeping and triggers
+	 * translation faults on ADJACENT portal mappings (affine CPU portals).
+	 *
+	 * Reserved portals are never accessed by kernel code, so keeping
+	 * the stale mapping is harmless. Userspace creates its own mapping
+	 * via remap_pfn_range() using the CORRECT addr_phys_ce.
+	 */
+
+	*pcfg_out = pcfg;
+	return 0;
+}
+EXPORT_SYMBOL(bman_portal_reserve);
+
+void bman_portal_release_reserved(struct bm_portal_config *pcfg)
+{
+	spin_lock(&bman_free_lock);
+	pcfg->reserved = false;
+	list_add_tail(&pcfg->list, &bman_free_portals);
+	spin_unlock(&bman_free_lock);
+}
+EXPORT_SYMBOL(bman_portal_release_reserved);
+
 static const struct of_device_id bman_portal_ids[] = {
 	{
 		.compatible = "fsl,bman-portal",
-- 
