From: VyOS LS1046A Build <build@vyos.io>
Date: Sat, 18 Apr 2026 04:20:00 +0000
Subject: [PATCH] usb: host: xhci-plat: force XHCI_AVOID_BEI on LS1046A DWC3

The LS1046A DWC3 posts BEI on bulk TRBs in a way the xHCI event
handler mishandles when the ring wraps, causing "xHCI host controller
not responding, assume dead" during USB-storage probe.

v1 of this patch walked tmpdev->of_node but the xhci-hcd platform
child created by dwc3_host_init() has of_node=NULL; only fwnode is
propagated (via pdevinfo.fwnode = dev_fwnode(dwc->dev)). This version
walks both of_node AND fwnode, and matches both fsl,ls1046a-dwc3 and
the generic snps,dwc3 compatible. A dev_info() is emitted so the boot
log unambiguously shows whether the quirk fired.

Signed-off-by: VyOS LS1046A Build <build@vyos.io>
---
--- a/drivers/usb/host/xhci-plat.c
+++ b/drivers/usb/host/xhci-plat.c
@@ -76,6 +76,32 @@ static int xhci_priv_resume_quirk(struct usb_hcd *hcd)
 static void xhci_plat_quirks(struct device *dev, struct xhci_hcd *xhci)
 {
 	struct xhci_plat_priv *priv = xhci_to_priv(xhci);
+	struct device *tmpdev;
+	bool ls1046a_dwc3 = false;
 
 	xhci->quirks |= priv->quirks;
+
+	/*
+	 * NXP LS1046A DWC3 errata: AVOID_BEI + TRUST_TX_LENGTH.
+	 * dwc3_host_init() sets fwnode (not of_node) on the xhci child,
+	 * so check both. Accept snps,dwc3 too (dwc3 core parent).
+	 */
+	for (tmpdev = dev; tmpdev; tmpdev = tmpdev->parent) {
+		if (tmpdev->of_node &&
+		    (of_device_is_compatible(tmpdev->of_node, "fsl,ls1046a-dwc3") ||
+		     of_device_is_compatible(tmpdev->of_node, "snps,dwc3"))) {
+			ls1046a_dwc3 = true;
+			break;
+		}
+		if (tmpdev->fwnode &&
+		    (fwnode_device_is_compatible(tmpdev->fwnode, "fsl,ls1046a-dwc3") ||
+		     fwnode_device_is_compatible(tmpdev->fwnode, "snps,dwc3"))) {
+			ls1046a_dwc3 = true;
+			break;
+		}
+	}
+	if (ls1046a_dwc3) {
+		xhci->quirks |= XHCI_AVOID_BEI | XHCI_TRUST_TX_LENGTH;
+		dev_info(dev, "LS1046A DWC3 quirks applied (AVOID_BEI|TRUST_TX_LENGTH)\n");
+	}
 }