         _normalize_buffers(effective_config)
         for iface_config in effective_config['settings']['interface'].values():
-            iface_config['driver'] = 'dpdk'
+            _edrv = eth_ifaces_persist.get(_ename, {}).get('original_driver', '')
+            if _edrv in platform_bus_xdp_drivers:
+                iface_config['driver'] = 'xdp'
+            else:
+                iface_config['driver'] = 'dpdk'
         config['effective'] = effective_config
@@ -399,4 +407,20 @@
 
             for iface, iface_config in config['settings']['interface'].items():
-                iface_config['driver'] = 'dpdk'
-
+                # Auto-detect driver: platform-bus NICs use XDP, PCI NICs use DPDK
+                _orig_drv = eth_ifaces_persist.get(iface, {}).get('original_driver', '')
+                if not _orig_drv:
+                    try:
+                        _orig_drv = EthtoolGDrvinfo(iface).driver
+                    except Exception:
+                        _orig_drv = ''
+                if _orig_drv in platform_bus_xdp_drivers:
+                    iface_config['driver'] = 'xdp'
+                    # Provide default XDP options if CLI does not expose them
+                    if 'xdp_options' not in iface_config:
+                        iface_config['xdp_options'] = {
+                            'rx_queue_size': '4096',
+                            'tx_queue_size': '4096',
+                            'num_rx_queues': 'all',
+                        }
+                else:
+                    iface_config['driver'] = 'dpdk'
