-not_pci_drv: list[str] = ['hv_netvsc']
+not_pci_drv: list[str] = ['hv_netvsc', 'fsl_dpa']
+
+# drivers on platform bus that must use XDP (not DPDK)
+platform_bus_xdp_drivers: list[str] = ['fsl_dpa']
 
 # drivers that support interrupt RX mode for DPDK and XDP
 drivers_support_interrupt: dict[str, list] = {
@@ -129,3 +132,4 @@
 SUPPORTED_DRIVERS = (
     'hv_netvsc',  # Microsoft Hyper-V network interface card
+    'fsl_dpa',  # NXP DPAA1 FMan Ethernet (platform bus, AF_XDP)
 )
@@ -376,5 +380,9 @@
