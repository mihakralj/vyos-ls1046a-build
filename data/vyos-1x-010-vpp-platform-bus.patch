Add platform-bus NIC support for VPP via AF_XDP.

NXP DPAA1 FMan Ethernet NICs (driver: fsl_dpa) are on the platform bus,
not PCI. VPP's default path hardcodes driver='dpdk' for all interfaces,
which crashes on platform-bus NICs. This patch:

1. Adds fsl_dpa to SUPPORTED_DRIVERS and not_pci_drv lists
2. Introduces platform_bus_xdp_drivers list for auto-detection
3. Auto-selects driver='xdp' for platform-bus NICs with XDP defaults
4. Enables af_xdp_plugin.so and conditionally disables dpdk_plugin.so
5. Lowers resource minimums for embedded ARM64 boards (2 CPUs, 256M heap)

Tested on NXP LS1046A Mono Gateway with VPP v25.10.0-48 AF_XDP on
eth3/eth4 (10G SFP+).

--- a/src/conf_mode/vpp.py
+++ b/src/conf_mode/vpp.py
@@ -94,7 +94,12 @@
 }
 
 # drivers that does not use PCIe addresses
-not_pci_drv: list[str] = ['hv_netvsc']
+not_pci_drv: list[str] = ['hv_netvsc', 'fsl_dpa']
+
+# drivers on platform bus that must use XDP (not DPDK)
+platform_bus_xdp_drivers: list[str] = ['fsl_dpa']
 
 # drivers that support interrupt RX mode for DPDK and XDP
 drivers_support_interrupt: dict[str, list] = {
@@ -131,3 +136,4 @@
 SUPPORTED_DRIVERS = (
     'hv_netvsc',  # Microsoft Hyper-V network interface card
+    'fsl_dpa',  # NXP DPAA1 FMan Ethernet (platform bus, AF_XDP)
 )
@@ -381,4 +387,9 @@
         for _ename, iface_config in effective_config['settings']['interface'].items():
-            iface_config['driver'] = 'dpdk'
+            _edrv = eth_ifaces_persist.get(_ename, {}).get('original_driver', '')
+            if _edrv in platform_bus_xdp_drivers:
+                iface_config['driver'] = 'xdp'
+            else:
+                iface_config['driver'] = 'dpdk'
         config['effective'] = effective_config
 
     # Save important info about all interfaces that cannot be retrieved later
@@ -407,4 +418,16 @@
 
             for iface, iface_config in config['settings']['interface'].items():
-                iface_config['driver'] = 'dpdk'
+                # Auto-detect driver: platform-bus NICs use XDP, PCI NICs use DPDK
+                _orig_drv = eth_ifaces_persist.get(iface, {}).get('original_driver', '')
+                if not _orig_drv:
+                    try:
+                        _orig_drv = EthtoolGDrvinfo(iface).driver
+                    except Exception:
+                        _orig_drv = ''
+                if _orig_drv in platform_bus_xdp_drivers:
+                    iface_config['driver'] = 'xdp'
+                    # Provide default XDP options if CLI does not expose them
+                    if 'xdp_options' not in iface_config:
+                        iface_config['xdp_options'] = {
+                            'rx_queue_size': '4096',
+                            'tx_queue_size': '4096',
+                            'num_rx_queues': 'all',
+                        }
+                else:
+                    iface_config['driver'] = 'dpdk'
 
                 # old_driver = leaf_node_changed(
