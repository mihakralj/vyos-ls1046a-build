#!/bin/bash
# vyos-postinstall — U-Boot boot helper for LS1046A Mono Gateway
#
# Two independent phases (each can succeed/fail without blocking the other):
#
#   Phase 1 — ONE-TIME U-Boot SPI flash setup:
#     Writes vyos, usb_vyos, bootcmd to SPI NOR via fw_setenv.
#     Runs on EVERY boot (USB live boot or eMMC installed boot).
#     Skips silently if already configured. No installed images required.
#
#   Phase 2 — EVERY INSTALL/UPGRADE: Write /boot/vyos.env:
#     Tells U-Boot which image to load. Skipped gracefully if no
#     installed images exist (normal on USB live boot before install).
#
# Called automatically by vyos-postinstall.service on every boot.
# Also called by image_installer.py (install_image hook) and grub.py
# (set_default hook) after install/upgrade.
#
# Usage:
#   sudo vyos-postinstall                              # auto-detect root & image
#   sudo vyos-postinstall <image-name>                 # explicit image, auto root
#   sudo vyos-postinstall --root /mnt/wroot <image>    # explicit root & image
#
# The --root flag is critical when called from install_image(), where the
# eMMC target is mounted at a non-standard path (e.g., /mnt/wroot).
# Without --root, find_root() may not discover the mount point.
#
# This script is a no-op on non-LS1046A hardware.

VYOS_ENV_FILE="vyos.env"
FW_ENV_CONFIG="/etc/fw_env.config"
UBOOT_BOOTARGS_TAIL="console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 net.ifnames=0 boot=live rootdelay=5 noautologin fsl_dpaa_fman.fsl_fm_max_frm=9600 panic=60"

# Accumulated exit code — set to 1 on any actual error, but script always runs to completion
RC=0

# ─── Board detection ────────────────────────────────────────────────────────

check_board() {
    local compat="/proc/device-tree/compatible"
    if [ ! -f "$compat" ]; then
        echo "Not running on a DeviceTree platform. Skipping."
        exit 0
    fi
    if ! tr '\0' '\n' < "$compat" | grep -q "fsl,ls1046a"; then
        echo "Not an LS1046A board. Skipping."
        exit 0
    fi
}

# ─── Phase 1: One-time U-Boot SPI flash setup ───────────────────────────────
#
# Writes static vyos (reads /boot/vyos.env → loads vmlinuz/dtb/initrd →
# booti), usb_vyos (FAT32 USB live boot), and bootcmd (try USB first, then
# eMMC, then SPI recovery).
#
# Safe to call repeatedly — checks current fw_printenv value first and skips
# if vyos already references vyos.env.

setup_uboot_env_once() {
    # U-Boot SPI flash env cannot be written from Linux on the Mono Gateway.
    # The DTS MTD partition map doesn't match the actual flash layout — mtd3
    # (labeled "u-boot-env") contains FMan microcode, not the env sector.
    # Therefore fw_setenv always fails with "Configuration file wrong or corrupted".
    #
    # The U-Boot vars (vyos, usb_vyos, bootcmd) must be set ONCE from the
    # U-Boot console via serial. After that, all image changes are handled
    # automatically via /boot/vyos.env (Phase 2 below).
    #
    # See INSTALL.md "Step 4 — Configure U-Boot" for the one-time commands.
    echo "NOTE: U-Boot SPI flash vars must be set via serial console (see INSTALL.md)."
    echo "  fw_setenv is not supported on this board (MTD partition mismatch)."
    return 0
}

# ─── Phase 2: Write /boot/vyos.env ──────────────────────────────────────────

# Find the persistence root (where /boot/<image-name>/ lives on eMMC).
# Returns empty string — not an error — if no installed images are found.
# This is normal during USB live boot before install image has been run.
find_root() {
    local candidate n

    for candidate in "/" "/mnt/root" "/mnt"; do
        if [ -d "${candidate}/boot" ]; then
            n=$(find "${candidate}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$n" -gt 0 ]; then
                echo "$candidate"
                return 0
            fi
        fi
    done

    # Scan all active mount points (catches /mnt/wroot used by install_image)
    while IFS= read -r mp; do
        [ -z "$mp" ] && continue
        if [ -d "${mp}/boot" ]; then
            n=$(find "${mp}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$n" -gt 0 ]; then
                echo "$mp"
                return 0
            fi
        fi
    done < <(mount | awk '{print $3}' | grep -v -E '^/(proc|sys|dev|run|snap)$')

    echo ""  # not found — caller handles this gracefully
}

detect_latest_image() {
    local root="$1"
    find "${root}/boot" -maxdepth 1 -mindepth 1 -type d -name '20*-*-rolling' \
        -printf '%f\n' 2>/dev/null | sort -r | head -1
}

# Determine image to boot — priority order:
#   1. Currently running image (from /proc/cmdline vyos-union= or BOOT_IMAGE=)
#   2. Existing vyos.env content (preserves user's set-default-boot choice)
#   3. Lexicographically latest (fallback for first install)
detect_current_image() {
    local root="$1"
    local img

    # 1. Currently running image from /proc/cmdline
    img=$(grep -oP '(?<=vyos-union=/boot/)[^ ]+' /proc/cmdline 2>/dev/null)
    if [ -n "$img" ] && [ -d "${root}/boot/${img}" ]; then
        echo "$img"
        return 0
    fi
    img=$(grep -oP '(?<=BOOT_IMAGE=/boot/)[^/]+' /proc/cmdline 2>/dev/null)
    if [ -n "$img" ] && [ -d "${root}/boot/${img}" ]; then
        echo "$img"
        return 0
    fi

    # 2. Existing vyos.env (preserves set-default-boot selection)
    local env_path="${root}/boot/${VYOS_ENV_FILE}"
    if [ -f "$env_path" ]; then
        img=$(grep -oP '(?<=vyos_image=)\S+' "$env_path" 2>/dev/null)
        if [ -n "$img" ] && [ -d "${root}/boot/${img}" ]; then
            echo "$img"
            return 0
        fi
    fi

    # 3. Fallback: lexicographically latest
    detect_latest_image "$root"
}

write_vyos_env() {
    local image_name="$1"
    local root="$2"
    local env_path="${root}/boot/${VYOS_ENV_FILE}"

    if printf 'vyos_image=%s\n' "$image_name" > "$env_path"; then
        echo "✓ Written: ${env_path} → vyos_image=${image_name}"
    else
        echo "ERROR: Cannot write ${env_path} — check permissions and mount state"
        RC=1
    fi
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    # Parse arguments: [--root <path>] [<image-name>]
    local explicit_root=""
    local image_name=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --root)
                shift
                explicit_root="${1:-}"
                shift
                ;;
            *)
                image_name="$1"
                shift
                ;;
        esac
    done

    check_board

    echo "=== VyOS Post-Install for LS1046A ==="

    # Phase 1: U-Boot SPI flash setup.
    # Runs unconditionally — does NOT require installed VyOS images.
    # On USB live boot: configures SPI flash so eMMC boot works after install.
    # On eMMC boot: already done, skips in ~1ms.
    setup_uboot_env_once

    # Phase 2: Write vyos.env.
    # If --root was given (e.g., from install_image), use it directly.
    # Otherwise auto-detect by scanning mount points.
    local root
    if [ -n "$explicit_root" ]; then
        root="$explicit_root"
        echo "Using explicit root: ${root}"
    else
        root=$(find_root)
    fi

    if [ -z "$root" ]; then
        echo ""
        echo "No installed VyOS images found — /boot/vyos.env write skipped."
        echo "(This is normal on USB live boot. Run 'install image' to install VyOS.)"
        exit $RC
    fi

    if [ -z "$image_name" ]; then
        image_name=$(detect_current_image "$root")
    fi

    if [ -z "$image_name" ]; then
        echo "WARNING: No VyOS image directories found under ${root}/boot/"
        exit $RC
    fi

    if [ ! -d "${root}/boot/${image_name}" ]; then
        echo "ERROR: Image directory '${root}/boot/${image_name}' does not exist"
        RC=1
        exit $RC
    fi

    echo "Image:  ${image_name}"
    echo "Root:   ${root}"
    echo ""
    write_vyos_env "$image_name" "$root"

    echo ""
    echo "=== Done ==="
    exit $RC
}

main "$@"