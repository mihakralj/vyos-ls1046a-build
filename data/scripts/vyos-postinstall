#!/bin/bash
# vyos-postinstall — Post-install/upgrade helper for LS1046A U-Boot boards
#
# Handles two things VyOS's image_installer.py doesn't:
#   1. Copies DTB to the boot directory of the specified image
#   2. Updates U-Boot environment via fw_setenv so the board boots the new image
#
# Usage:
#   After 'install image':     sudo vyos-postinstall
#   After 'add system image':  sudo vyos-postinstall <image-name>
#
# Auto-detection picks the image with the latest version string.
# This script is a no-op on non-LS1046A hardware.

set -euo pipefail

DTB_NAME="mono-gw.dtb"
FW_ENV_CONFIG="/etc/fw_env.config"
UBOOT_BOOTARGS="console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 net.ifnames=0 boot=live rootdelay=5 noautologin"

#--- Board detection ---
check_board() {
    local compat="/proc/device-tree/compatible"
    if [ ! -f "$compat" ]; then
        echo "Not running on a DeviceTree platform. Skipping."
        exit 0
    fi
    if ! tr '\0' '\n' < "$compat" | grep -q "fsl,ls1046a"; then
        echo "Not an LS1046A board. Skipping."
        exit 0
    fi
}

#--- Find persistence root (where /boot/{image}/ lives on eMMC) ---
find_root() {
    # After 'install image', VyOS mounts the eMMC persistence partition.
    # Check well-known paths first, then scan all mounted filesystems.
    for candidate in "/" "/mnt/root" "/mnt"; do
        if [ -d "${candidate}/boot" ]; then
            local images
            images=$(find "${candidate}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$images" -gt 0 ]; then
                echo "$candidate"
                return 0
            fi
        fi
    done
    # Scan all mounted filesystems for VyOS image directories
    while IFS= read -r mpoint; do
        if [ -d "${mpoint}/boot" ]; then
            local images
            images=$(find "${mpoint}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$images" -gt 0 ]; then
                echo "$mpoint"
                return 0
            fi
        fi
    done < <(mount | awk '{print $3}' | grep -v -E '^/(proc|sys|dev|run)')
    echo "ERROR: Cannot find persistence root with VyOS image directories in /boot/" >&2
    echo "Mount eMMC first: sudo mount /dev/mmcblk0p3 /mnt" >&2
    return 1
}

#--- Find DTB source ---
find_dtb() {
    # Priority 1: DTB compiled into squashfs at /boot/
    if [ -f "/boot/${DTB_NAME}" ]; then
        echo "/boot/${DTB_NAME}"
        return 0
    fi
    # Priority 2: Live FDT from running kernel
    if [ -f "/sys/firmware/fdt" ]; then
        echo "/sys/firmware/fdt"
        return 0
    fi
    echo "ERROR: No DTB source found" >&2
    return 1
}

#--- Resolve actual boot filenames (handles versioned names) ---
resolve_boot_files() {
    local boot_dir="$1"

    # Kernel: prefer 'vmlinuz', fall back to 'vmlinuz-*'
    if [ -f "${boot_dir}/vmlinuz" ]; then
        KERNEL_FILE="vmlinuz"
    else
        KERNEL_FILE=$(cd "$boot_dir" && ls vmlinuz-* 2>/dev/null | head -1)
    fi
    if [ -z "${KERNEL_FILE:-}" ]; then
        echo "ERROR: No kernel found in ${boot_dir}" >&2
        return 1
    fi

    # Initrd: prefer 'initrd.img', fall back to 'initrd.img-*'
    if [ -f "${boot_dir}/initrd.img" ]; then
        INITRD_FILE="initrd.img"
    else
        INITRD_FILE=$(cd "$boot_dir" && ls initrd.img-* 2>/dev/null | head -1)
    fi
    if [ -z "${INITRD_FILE:-}" ]; then
        echo "ERROR: No initrd found in ${boot_dir}" >&2
        return 1
    fi

    echo "  Kernel: ${KERNEL_FILE}"
    echo "  Initrd: ${INITRD_FILE}"
    echo "  DTB:    ${DTB_NAME}"
}

#--- Copy DTB to target image ---
copy_dtb() {
    local image_name="$1"
    local root="$2"
    local boot_dir="${root}/boot/${image_name}"

    if [ ! -d "$boot_dir" ]; then
        echo "ERROR: Boot directory does not exist: ${boot_dir}" >&2
        return 1
    fi

    local dtb_src
    dtb_src=$(find_dtb)
    local dtb_dst="${boot_dir}/${DTB_NAME}"

    cp "$dtb_src" "$dtb_dst"
    echo "✓ DTB: ${dtb_src} → ${dtb_dst} ($(stat -c '%s' "$dtb_dst") bytes)"
}

#--- Update U-Boot environment ---
update_uboot_env() {
    local image_name="$1"
    local root="$2"
    local boot_dir="${root}/boot/${image_name}"

    if ! command -v fw_setenv &>/dev/null; then
        echo "ERROR: fw_setenv not found. Install u-boot-tools." >&2
        return 1
    fi

    if [ ! -f "$FW_ENV_CONFIG" ]; then
        echo "ERROR: ${FW_ENV_CONFIG} not found." >&2
        return 1
    fi

    # Resolve actual filenames (handles vmlinuz vs vmlinuz-<version>)
    resolve_boot_files "$boot_dir"

    # Build the vyos_direct boot command
    # CRITICAL: initrd must be loaded LAST so ${filesize} captures its size for booti
    local vyos_direct
    vyos_direct="ext4load mmc 0:3 \${kernel_addr_r} boot/${image_name}/${KERNEL_FILE}; ext4load mmc 0:3 \${fdt_addr_r} boot/${image_name}/${DTB_NAME}; ext4load mmc 0:3 \${ramdisk_addr_r} boot/${image_name}/${INITRD_FILE}; setenv bootargs ${UBOOT_BOOTARGS} vyos-union=/boot/${image_name}; booti \${kernel_addr_r} \${ramdisk_addr_r}:\${filesize} \${fdt_addr_r}"

    fw_setenv vyos_direct "$vyos_direct"
    fw_setenv bootcmd "run vyos_direct || run recovery"
    echo "✓ U-Boot: vyos_direct → boot/${image_name}/"
    echo "✓ U-Boot: bootcmd → 'run vyos_direct || run recovery'"
}

#--- List available images ---
list_images() {
    local root="$1"
    echo "Available images:"
    for dir in "${root}/boot"/20*-*-rolling/; do
        [ ! -d "$dir" ] && continue
        local name
        name=$(basename "$dir")
        local has_kernel="✗" has_dtb="✗" has_squashfs="✗"
        { [ -f "${dir}/vmlinuz" ] || ls "${dir}"/vmlinuz-* &>/dev/null; } && has_kernel="✓"
        [ -f "${dir}/${DTB_NAME}" ] && has_dtb="✓"
        ls "${dir}"/*.squashfs &>/dev/null && has_squashfs="✓"
        printf "  %-45s kernel=%s dtb=%s squashfs=%s\n" "$name" "$has_kernel" "$has_dtb" "$has_squashfs"
    done
}

#--- Auto-detect latest image by version string ---
detect_latest_image() {
    local root="$1"
    # VyOS image names are YYYY.MM.DD-HHMM-rolling — lexicographic sort = version sort
    local latest
    latest=$(find "${root}/boot" -maxdepth 1 -mindepth 1 -type d -name '20*-*-rolling' \
        -printf '%f\n' 2>/dev/null | sort -r | head -1)
    echo "$latest"
}

#--- Main ---
main() {
    check_board

    local root
    root=$(find_root)
    local image_name="${1:-}"

    # Auto-detect: pick the image with the latest version string
    if [ -z "$image_name" ]; then
        image_name=$(detect_latest_image "$root")
        if [ -n "$image_name" ]; then
            echo "Auto-detected image: ${image_name}"
        else
            echo "ERROR: No VyOS image found. Specify image name as argument." >&2
            list_images "$root"
            exit 1
        fi
    fi

    # Validate
    if [ ! -d "${root}/boot/${image_name}" ]; then
        echo "ERROR: Image '${image_name}' not found at ${root}/boot/${image_name}" >&2
        list_images "$root"
        exit 1
    fi

    echo "=== VyOS Post-Install for LS1046A ==="
    echo "Image:  ${image_name}"
    echo "Root:   ${root}"
    echo ""

    copy_dtb "$image_name" "$root"
    echo ""
    update_uboot_env "$image_name" "$root"

    echo ""
    echo "=== Done. Reboot to boot from eMMC. ==="
}

main "$@"
