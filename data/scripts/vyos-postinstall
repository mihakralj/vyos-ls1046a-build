#!/bin/bash
# vyos-postinstall — U-Boot boot helper for LS1046A Mono Gateway
#
# Two independent phases (each can succeed/fail without blocking the other):
#
#   Phase 1 — ONE-TIME U-Boot SPI flash setup:
#     Writes vyos_direct, usb_vyos, bootcmd to SPI NOR via fw_setenv.
#     Runs on EVERY boot (USB live boot or eMMC installed boot).
#     Skips silently if already configured. No installed images required.
#
#   Phase 2 — EVERY INSTALL/UPGRADE: Write /boot/vyos.env:
#     Tells U-Boot which image to load. Skipped gracefully if no
#     installed images exist (normal on USB live boot before install).
#
# Called automatically by vyos-postinstall.service on every boot.
# Also called by image_installer.py (install_image hook) and grub.py
# (set_default hook) after install/upgrade.
#
# Usage:
#   sudo vyos-postinstall              # auto-detect latest installed image
#   sudo vyos-postinstall <image-name> # explicit image name
#
# This script is a no-op on non-LS1046A hardware.

VYOS_ENV_FILE="vyos.env"
FW_ENV_CONFIG="/etc/fw_env.config"
UBOOT_BOOTARGS_TAIL="console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 net.ifnames=0 boot=live rootdelay=5 noautologin fsl_dpaa_fman.fsl_fm_max_frm=9600 hugepagesz=2M hugepages=512 panic=60"

# Accumulated exit code — set to 1 on any actual error, but script always runs to completion
RC=0

# ─── Board detection ────────────────────────────────────────────────────────

check_board() {
    local compat="/proc/device-tree/compatible"
    if [ ! -f "$compat" ]; then
        echo "Not running on a DeviceTree platform. Skipping."
        exit 0
    fi
    if ! tr '\0' '\n' < "$compat" | grep -q "fsl,ls1046a"; then
        echo "Not an LS1046A board. Skipping."
        exit 0
    fi
}

# ─── Phase 1: One-time U-Boot SPI flash setup ───────────────────────────────
#
# Writes static vyos_direct (reads /boot/vyos.env → loads vmlinuz/dtb/initrd →
# booti), usb_vyos (FAT32 USB live boot), and bootcmd (try USB first, then
# eMMC, then SPI recovery).
#
# Safe to call repeatedly — checks current fw_printenv value first and skips
# if vyos_direct already references vyos.env.

setup_uboot_env_once() {
    if ! command -v fw_printenv &>/dev/null; then
        echo "WARNING: fw_printenv not found. Is libubootenv-tool installed?"
        echo "  U-Boot SPI flash setup skipped. See INSTALL.md for manual steps."
        return 0
    fi
    if [ ! -f "$FW_ENV_CONFIG" ]; then
        echo "WARNING: ${FW_ENV_CONFIG} missing."
        echo "  U-Boot SPI flash setup skipped. See INSTALL.md for manual steps."
        return 0
    fi

    local current
    current=$(fw_printenv vyos_direct 2>/dev/null || echo "")
    if echo "$current" | grep -q "vyos.env"; then
        echo "✓ U-Boot SPI flash already configured (vyos_direct references vyos.env)."
        return 0
    fi

    echo "=== First-time U-Boot SPI flash setup ==="

    # vyos_direct: read /boot/vyos.env, import vyos_image, load vmlinuz/dtb/initrd, booti
    # CRITICAL ORDERING: initrd loaded LAST so ${filesize} captures its size for booti
    # CRITICAL BOOTARGS: BOOT_IMAGE= must be first; VyOS is_live_boot() requires it
    # CRITICAL ADDRESS: DTB at ${fdt_addr_r} = 0x88000000; NEVER use 0x90000000
    local vyos_direct
    vyos_direct='ext4load mmc 0:3 ${load_addr} /boot/vyos.env; env import -t ${load_addr} ${filesize}; ext4load mmc 0:3 ${kernel_addr_r} /boot/${vyos_image}/vmlinuz; ext4load mmc 0:3 ${fdt_addr_r} /boot/${vyos_image}/mono-gw.dtb; ext4load mmc 0:3 ${ramdisk_addr_r} /boot/${vyos_image}/initrd.img; setenv bootargs "BOOT_IMAGE=/boot/${vyos_image}/vmlinuz '"${UBOOT_BOOTARGS_TAIL}"' vyos-union=/boot/${vyos_image}"; booti ${kernel_addr_r} ${ramdisk_addr_r}:${filesize} ${fdt_addr_r}'

    # usb_vyos: FAT32 USB live boot (for initial install and recovery)
    # Layout expected on USB: /live/vmlinuz, /live/initrd.img, /live/filesystem.squashfs, /mono-gw.dtb
    local usb_vyos
    usb_vyos='usb start; if fatload usb 0:1 ${kernel_addr_r} live/vmlinuz; then fatload usb 0:1 ${fdt_addr_r} mono-gw.dtb; fatload usb 0:1 ${ramdisk_addr_r} live/initrd.img; setenv bootargs "BOOT_IMAGE=/live/vmlinuz console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 boot=live live-media=/dev/sda1 components noeject nopersistence noautologin nonetworking union=overlay net.ifnames=0 fsl_dpaa_fman.fsl_fm_max_frm=9600 quiet"; booti ${kernel_addr_r} ${ramdisk_addr_r}:${filesize} ${fdt_addr_r}; fi'

    local ok=true
    fw_setenv vyos_direct "$vyos_direct" || ok=false
    fw_setenv usb_vyos    "$usb_vyos"    || ok=false
    fw_setenv bootcmd     "run usb_vyos || run vyos_direct || run recovery" || ok=false

    if $ok; then
        echo "✓ U-Boot: vyos_direct, usb_vyos, bootcmd written to SPI flash"
    else
        echo "ERROR: fw_setenv failed — one or more U-Boot variables NOT updated"
        echo "  Check that /dev/mtd3 exists and kernel has CONFIG_SPI_FSL_QSPI=y"
        RC=1
    fi
}

# ─── Phase 2: Write /boot/vyos.env ──────────────────────────────────────────

# Find the persistence root (where /boot/<image-name>/ lives on eMMC).
# Returns empty string — not an error — if no installed images are found.
# This is normal during USB live boot before install image has been run.
find_root() {
    local candidate n

    for candidate in "/" "/mnt/root" "/mnt"; do
        if [ -d "${candidate}/boot" ]; then
            n=$(find "${candidate}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$n" -gt 0 ]; then
                echo "$candidate"
                return 0
            fi
        fi
    done

    # Scan all active mount points (catches /mnt/wroot used by install_image)
    while IFS= read -r mp; do
        [ -z "$mp" ] && continue
        if [ -d "${mp}/boot" ]; then
            n=$(find "${mp}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$n" -gt 0 ]; then
                echo "$mp"
                return 0
            fi
        fi
    done < <(mount | awk '{print $3}' | grep -v -E '^/(proc|sys|dev|run|snap)$')

    echo ""  # not found — caller handles this gracefully
}

detect_latest_image() {
    local root="$1"
    find "${root}/boot" -maxdepth 1 -mindepth 1 -type d -name '20*-*-rolling' \
        -printf '%f\n' 2>/dev/null | sort -r | head -1
}

write_vyos_env() {
    local image_name="$1"
    local root="$2"
    local env_path="${root}/boot/${VYOS_ENV_FILE}"

    if printf 'vyos_image=%s\n' "$image_name" > "$env_path"; then
        echo "✓ Written: ${env_path} → vyos_image=${image_name}"
    else
        echo "ERROR: Cannot write ${env_path} — check permissions and mount state"
        RC=1
    fi
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    check_board

    echo "=== VyOS Post-Install for LS1046A ==="

    # Phase 1: U-Boot SPI flash setup.
    # Runs unconditionally — does NOT require installed VyOS images.
    # On USB live boot: configures SPI flash so eMMC boot works after install.
    # On eMMC boot: already done, skips in ~1ms.
    setup_uboot_env_once

    # Phase 2: Write vyos.env.
    # Requires an installed image directory under /boot/.
    # On USB live boot (before install image): find_root returns "", skip gracefully.
    # On eMMC installed boot: writes /boot/vyos.env for the running image.
    local root
    root=$(find_root)

    if [ -z "$root" ]; then
        echo ""
        echo "No installed VyOS images found — /boot/vyos.env write skipped."
        echo "(This is normal on USB live boot. Run 'install image' to install VyOS.)"
        exit $RC
    fi

    local image_name="${1:-}"
    if [ -z "$image_name" ]; then
        image_name=$(detect_latest_image "$root")
    fi

    if [ -z "$image_name" ]; then
        echo "WARNING: No VyOS image directories found under ${root}/boot/"
        exit $RC
    fi

    if [ ! -d "${root}/boot/${image_name}" ]; then
        echo "ERROR: Image directory '${root}/boot/${image_name}' does not exist"
        RC=1
        exit $RC
    fi

    echo "Image:  ${image_name}"
    echo "Root:   ${root}"
    echo ""
    write_vyos_env "$image_name" "$root"

    echo ""
    echo "=== Done ==="
    exit $RC
}

main "$@"