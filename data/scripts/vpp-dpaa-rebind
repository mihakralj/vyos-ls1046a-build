#!/bin/bash
# Rebind DPAA1 interfaces back to kernel fsl_dpa after VPP stops.
STATE=/run/vpp-dpaa-unbound.json
BIND=/sys/bus/platform/drivers/fsl_dpa/bind
[ -f "$STATE" ] || exit 0
python3 - <<PYEOF
import json, os, sys
state_file = "/run/vpp-dpaa-unbound.json"
bind_path  = "/sys/bus/platform/drivers/fsl_dpa/bind"
try:
    unbound = json.load(open(state_file))
except Exception:
    raise SystemExit(0)
if os.path.exists(bind_path):
    for iface, dev in unbound.items():
        try:
            open(bind_path, "w").write(dev)
            print(f"vpp-dpaa-rebind: restored {iface} ({dev}) to fsl_dpa")
        except OSError as e:
            print(f"vpp-dpaa-rebind: failed {iface}: {e}", file=__import__("sys").stderr)
try:
    os.unlink(state_file)
except OSError:
    pass
PYEOF
