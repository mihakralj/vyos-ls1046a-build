# === USB live boot support (built-in for initramfs FAT32 access) ===
CONFIG_USB_STORAGE=y
CONFIG_VFAT_FS=y
CONFIG_FAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y

# === LS1046A xHCI + DWC3 USB glue (required on kernel 6.6) ===
# Kernel 6.1 had these defaulted on; 6.6 made them opt-in per board.
# Without USB_XHCI_PLATFORM the xhci-hcd core loads but has no platform
# binding → "WARNING: Host System Error" and USB mass-storage fails to
# enumerate ("couldn't allocate usb_device") → live-boot cannot find the
# squashfs and the initramfs hangs.
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_COMMON=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_HOST=y
CONFIG_USB_DWC3_OF_SIMPLE=y
CONFIG_USB_FSL_MPH_DR_OF=y
