# === LS1046A is a Layerscape SoC — must enable ARCH_LAYERSCAPE ===
# VyOS generic ARM64 defconfig doesn't set this, so all drivers with
# "depends on ARCH_LAYERSCAPE" (SPI_FSL_QUADSPI, I2C_IMX, IMX2_WDT,
# NET_VENDOR_FREESCALE, CLK_QORIQ, QORIQ_CPUFREQ, MMC_SDHCI_OF_ESDHC,
# etc.) get silently stripped by make olddefconfig. Enabling it here
# fixes all of them at once. Only selects EDAC_SUPPORT (harmless).
CONFIG_ARCH_LAYERSCAPE=y

# === Board peripherals (fan, thermal, RTC, power sensors) ===
CONFIG_SENSORS_EMC2305=y
CONFIG_SENSORS_INA2XX=y
CONFIG_RTC_DRV_PCF2127=y

# === QorIQ platform (clock, CPU freq) ===
# CLK_QORIQ is critical — without it FMan probe fails with
# "Failed to get FM clock structure" error -5 and system freezes.
# ARCH_LAYERSCAPE dep removed by patch 5009; must be explicitly enabled.
CONFIG_CLK_QORIQ=y