# === NXP SDK DPAA1 driver stack (replaces mainline fman/dpaa/qbman) ===
# Mutual exclusion: SDK drivers depend on mainline equivalents being OFF

# Disable mainline DPAA1 stack
# CONFIG_FSL_DPAA is not set
# CONFIG_FSL_FMAN is not set
# CONFIG_FSL_DPAA_ETH is not set
# CONFIG_FSL_FMD_SHIM is not set

# Enable SDK BMan/QMan (staging/fsl_qbman)
CONFIG_FSL_SDK_DPA=y
CONFIG_FSL_SDK_BMAN=y
CONFIG_FSL_BMAN_CONFIG=y
CONFIG_FSL_SDK_QMAN=y
CONFIG_FSL_QMAN_CONFIG=y

# Enable SDK FMan (includes full PCD + /dev/fm0* chardevs)
# FMAN_ARM = ARM64 platform I/O accessors (choice: mutually exclusive with FMAN_V3H/V3L/P3040)
# LS1046A is ARM64 with FMan v3H silicon, but Kconfig "Processor Type" choice = FMAN_ARM
CONFIG_FSL_SDK_FMAN=y
CONFIG_FMAN_ARM=y
# CONFIG_FMAN_V3H is not set
# CONFIG_FMAN_P3040_P4080_P5020 is not set
# CONFIG_FMAN_P1023 is not set
# CONFIG_FMAN_V3L is not set

# Enable SDK DPAA ethernet (creates eth0-eth4 via fsl,dpa-ethernet DTS nodes)
CONFIG_FSL_SDK_DPAA_ETH=y
CONFIG_FSL_DPAA_HOOKS=y

# Staging tree must be enabled (SDK QBMan lives in drivers/staging/fsl_qbman)
CONFIG_STAGING=y

# FORTIFY_SOURCE conflicts with SDK NCSW stdlib_ext.h strlen declaration
# CONFIG_FORTIFY_SOURCE is not set

# STRICT_DEVMEM must be off for DPDK fmlib mmap (future pass)
# CONFIG_STRICT_DEVMEM is not set
# CONFIG_IO_STRICT_DEVMEM is not set

# SFP/PHYLINK must be =y (not =m) for TFTP dev boot (no modules).
# Mainline FSL_FMAN does `select PHYLINK` but SDK disables it above,
# so phylink/sfp fall back to =m from VyOS defconfig. Force built-in
# so SFP cage management (TX_DISABLE, rollball PHY I2C) works on SDK.
CONFIG_PHYLINK=y
CONFIG_SFP=y

# XGMAC_MDIO probes external MDIO buses where RJ45 PHYs (GPY115C) live.
# Mainline Kconfig depends on FSL_FMAN which SDK disables — the injection
# script patches Kconfig to also accept FSL_SDK_FMAN. Without this driver,
# MDIO bus never probes → PHYs not discovered → RJ45 ports stay DOWN.
CONFIG_FSL_XGMAC_MDIO=y
