# === Extra kernel configs to match dev kernel capabilities ===
# These bring the CI build in line with the locally-built dev kernel.

# --- KVM virtualization (built-in for arm64) ---
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y

# --- NFS client (built-in for TFTP/network boot scenarios) ---
CONFIG_NFS_FS=y
CONFIG_NFS_V3=y
CONFIG_NFS_V4=y
CONFIG_NFS_V4_1=y
CONFIG_NFS_V4_2=y
CONFIG_SUNRPC=y
CONFIG_SUNRPC_GSS=y
CONFIG_LOCKD=y

# --- VFIO (userspace device access framework) ---
CONFIG_VFIO=y
CONFIG_VFIO_NOIOMMU=y

# --- CMA (Contiguous Memory Allocator — 32MB for DMA/USDPAA) ---
CONFIG_CMA=y
CONFIG_DMA_CMA=y
CONFIG_CMA_SIZE_MBYTES=32

# --- Thermal: power_allocator governor (intelligent thermal management) ---
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
# Remove unnecessary thermal governors (dev only has step_wise + user_space + power_allocator)
# CONFIG_THERMAL_GOV_FAIR_SHARE is not set
# CONFIG_THERMAL_GOV_BANG_BANG is not set

# --- cpuidle: menu governor only (no ladder — saves boot time) ---
# CONFIG_CPU_IDLE_GOV_LADDER is not set

# --- STRICT_DEVMEM disabled (required for DPDK DPAA PMD /dev/mem access) ---
# CONFIG_STRICT_DEVMEM is not set
# CONFIG_IO_STRICT_DEVMEM is not set