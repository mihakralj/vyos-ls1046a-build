# ASK (Application Solutions Kit) kernel config for LS1046A
# Enables NXP hardware fast-path packet offload via FMAN silicon classifier
# NOTE: This REPLACES mainline DPAA ETH with NXP SDK DPAA ETH

# --- Platform prerequisite (ARCH_LAYERSCAPE requires ARCH_NXP) ---
CONFIG_ARCH_NXP=y
CONFIG_ARCH_LAYERSCAPE=y

# --- ASK Core Fast Path ---
CONFIG_CPE_FAST_PATH=y

# --- Disable mainline DPAA (conflicts with SDK) ---
# CONFIG_FSL_DPAA is not set
# CONFIG_FSL_FMAN is not set
# CONFIG_FSL_DPAA_ETH is not set

# --- NXP SDK DPAA stack (replaces mainline) ---
CONFIG_FSL_SDK_DPA=y
CONFIG_FSL_SDK_BMAN=y
CONFIG_FSL_SDK_QMAN=y
CONFIG_FSL_SDK_FMAN=y
CONFIG_FSL_SDK_DPAA_ETH=y
CONFIG_FSL_DPAA_HOOKS=y
CONFIG_FSL_DPAA_1588=y
CONFIG_FSL_DPAA_ETH_MAX_BUF_COUNT=640

# --- ASK Netfilter Extensions ---
CONFIG_NETFILTER_XT_QOSMARK=y
CONFIG_NETFILTER_XT_QOSCONNMARK=y

# --- IPsec Hardware Offload ---
CONFIG_INET_IPSEC_OFFLOAD=y
CONFIG_INET6_IPSEC_OFFLOAD=y

# --- Module versioning (required for out-of-tree ASK modules: cdx, fci, auto_bridge) ---
CONFIG_MODVERSIONS=y