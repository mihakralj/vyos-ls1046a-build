# ASK (Application Solutions Kit) kernel config for LS1046A
# Enables NXP hardware fast-path packet offload via FMAN silicon classifier
# NOTE: This REPLACES mainline DPAA ETH with NXP SDK DPAA ETH

# --- Platform prerequisite (ARCH_LAYERSCAPE requires ARCH_NXP) ---
CONFIG_ARCH_NXP=y
CONFIG_ARCH_LAYERSCAPE=y

# --- Staging drivers (REQUIRED: SDK QBMan lives in drivers/staging/fsl_qbman/) ---
# Without this, drivers/staging/ is never entered → QMan/BMan never compiled
# → SDK FMan link fails with "undefined reference to qman_*"
CONFIG_STAGING=y

# --- ASK Core Fast Path ---
CONFIG_CPE_FAST_PATH=y

# --- Disable mainline DPAA (conflicts with SDK) ---
# CONFIG_FSL_DPAA is not set
# CONFIG_FSL_FMAN is not set
# CONFIG_FSL_DPAA_ETH is not set

# --- NXP SDK DPAA stack (replaces mainline) ---
CONFIG_FSL_SDK_DPA=y
CONFIG_FSL_SDK_BMAN=y
CONFIG_FSL_SDK_QMAN=y
CONFIG_FSL_SDK_FMAN=y
CONFIG_FSL_SDK_DPAA_ETH=y
CONFIG_FSL_DPAA_HOOKS=y
CONFIG_FSL_DPAA_1588=y
CONFIG_FSL_DPAA_ETH_MAX_BUF_COUNT=640

# --- ASK Netfilter Extensions ---
CONFIG_NETFILTER_XT_QOSMARK=y
CONFIG_NETFILTER_XT_QOSCONNMARK=y

# --- IPsec Hardware Offload (CDX needs FM_PORT_SetDiscardMask) ---
CONFIG_XFRM=y
CONFIG_XFRM_USER=y
CONFIG_XFRM_ALGO=y
CONFIG_INET_ESP=y
CONFIG_INET_AH=y
CONFIG_INET6_ESP=y
CONFIG_INET6_AH=y
CONFIG_INET_IPSEC_OFFLOAD=y
CONFIG_INET6_IPSEC_OFFLOAD=y
CONFIG_CRYPTO_AUTHENC=y
CONFIG_CRYPTO_ECHAINIV=y
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SEQIV=y
CONFIG_NET_KEY=y

# --- IPv6 built-in (=m breaks TFTP boot — sysctl/neigh/multipath missing) ---
CONFIG_IPV6=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_SUBTREES=y
CONFIG_IPV6_MROUTE=y

# --- nftables (VyOS firewall uses nftables, not iptables) ---
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_LOG=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_FIB_INET=y
CONFIG_NFT_FIB_IPV4=y
CONFIG_NFT_FIB_IPV6=y

# --- Netfilter/conntrack built-in (TFTP boot has no modules) ---
CONFIG_NF_NAT=y
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_NF_CONNTRACK_TIMESTAMP=y
CONFIG_NF_CONNTRACK_TIMEOUT=y
CONFIG_NF_CT_NETLINK=y
CONFIG_NF_CT_NETLINK_TIMEOUT=y
CONFIG_NF_CT_NETLINK_HELPER=y
CONFIG_NETFILTER_NETLINK_GLUE_CT=y
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_NAT=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_LOG=y
CONFIG_NETFILTER_XT_TARGET_CHECKSUM=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y

# --- Routing (VyOS applies fib_multipath sysctls at boot) ---
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_ROUTE_MULTIPATH=y

# --- Filesystems (TFTP boot needs built-in) ---
CONFIG_FUSE_FS=y
CONFIG_SQUASHFS_XATTR=y

# --- Debug (VyOS system_option.py requires dynamic_debug control file) ---
CONFIG_DYNAMIC_DEBUG=y

# --- CAAM crypto engine built-in (CDX IPsec offload needs CAAM symbols in vmlinux) ---
CONFIG_CRYPTO_DEV_FSL_CAAM=y
CONFIG_CRYPTO_DEV_FSL_CAAM_JR=y
CONFIG_CRYPTO_DEV_FSL_CAAM_COMMON=y
CONFIG_CRYPTO_DEV_FSL_CAAM_CRYPTO_API_DESC=y
CONFIG_CRYPTO_DEV_FSL_CAAM_AHASH_API_DESC=y

# --- Module versioning (required for out-of-tree ASK modules: cdx, fci, auto_bridge) ---
CONFIG_MODVERSIONS=y
