+# LS1046A eMMC: first 32 MiB reserved for NXP firmware (U-Boot, RCW, PBI).
+# Partitions must start AFTER this zone.  sgdisk -Z and wipefs on the raw
+# device would overwrite LBA 0 and destroy the firmware.
+_FIRMWARE_RESERVED_SECTORS = 65536   # 32 MiB / 512 bytes per sector
+_BIOS_BOOT_START           = 65536   # sector (32 MiB)
+_BIOS_BOOT_END             = 67583   # sector (32 MiB + 1 MiB - 1)
+_EFI_START                 = 67584   # sector (33 MiB)
+
+def _is_emmc(drive_path: str) -> bool:
+    """Return True if drive_path is an eMMC device (mmcblk)."""
+    return 'mmcblk' in _basename(drive_path)
