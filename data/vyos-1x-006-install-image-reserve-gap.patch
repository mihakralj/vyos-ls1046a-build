Reserve first 32 MiB for NXP LS1046A firmware boundary.

Also update CONST_RESERVED_SPACE to account for the larger firmware
zone (32 MiB instead of 2 MiB), so sgdisk does not try to create a
root partition extending past the end of the disk.

diff --git a/python/vyos/system/disk.py b/python/vyos/system/disk.py
index 7ae9a15..4792350 100644
--- a/python/vyos/system/disk.py
+++ b/python/vyos/system/disk.py
@@ -62,8 +62,9 @@ def find_persistence() -> str:
 def parttable_create(drive_path: str, root_size: int) -> None:
     """Create a hybrid MBR/GPT partition table
     0-2047 first sectors are free
-    2048-4095 sectors - BIOS Boot Partition
-    4096 + 256 MB - EFI system partition
+    0-65535 (first 32 MiB) reserved for NXP LS1046A firmware boundary
+    65536-67583 sectors (32-33 MiB) - BIOS Boot Partition
+    67584 + 256 MB - EFI system partition
     Everything else till the end of a drive - Linux partition
 
     Args:
@@ -73,7 +74,7 @@ def parttable_create(drive_path: str, root_size: int) -> None:
         root_size_text: str = '+100%'
     else:
         root_size_text: str = str(root_size)
-    command = f'sgdisk -a1 -n1:2048:4095 -t1:EF02 -n2:4096:+256M -t2:EF00 \
+    command = f'sgdisk -a1 -n1:65536:67583 -t1:EF02 -n2:67584:+256M -t2:EF00 \
         -n3:0:+{root_size_text}K -t3:8300 {drive_path}'
 
     run(command)
diff --git a/src/op_mode/image_installer.py b/src/op_mode/image_installer.py
index cb3aa7b..e1f2a3c 100755
--- a/src/op_mode/image_installer.py
+++ b/src/op_mode/image_installer.py
@@ -118,8 +118,8 @@
 'Do you want to continue with installation?'
 CONST_MIN_DISK_SIZE: int = 2147483648  # 2 GB
 CONST_MIN_ROOT_SIZE: int = 1610612736  # 1.5 GB
-# a reserved space: 2MB for header, 1 MB for BIOS partition, 256 MB for EFI
-CONST_RESERVED_SPACE: int = (2 + 1 + 256) * 1024**2
+# a reserved space: 32MB firmware zone, 1 MB for BIOS partition, 256 MB for EFI
+CONST_RESERVED_SPACE: int = (32 + 1 + 256) * 1024**2
 
 # define directories and paths
 DIR_CONFIG: str = directories['config']