--- a/drivers/bus/dpaa/base/qbman/process.c
+++ b/drivers/bus/dpaa/base/qbman/process.c
@@ -7,6 +7,8 @@
 #include <assert.h>
 #include <fcntl.h>
 #include <unistd.h>
+#include <sys/mman.h>
+#include <stdint.h>
 #include <sys/ioctl.h>
 #include <rte_ethdev.h>
 
@@ -133,6 +135,36 @@
 #define DPAA_IOCTL_PORTAL_UNMAP \
 	_IOW(DPAA_IOCTL_MAGIC, 0x08, struct dpaa_portal_map)
 
+/*
+ * Portal window sizes for QBMan portals on LS1046A.
+ * CE (cache-enabled)  = 16KB (0x4000) per device-tree reg property
+ * CI (cache-inhibited) = 16KB (0x4000)
+ *
+ * On mainline kernels, PORTAL_MAP ioctl returns physical addresses
+ * (not virtual). DPDK must mmap() portal windows via the usdpaa fd.
+ * The kernel mmap handler sets correct page protection:
+ *   CE: Write-Back Non-Shareable (QBMan stashing protocol)
+ *   CI: Strongly-Ordered / Device-nGnRnE (portal doorbells)
+ */
+#define DPAA_PORTAL_CE_SIZE	0x4000
+#define DPAA_PORTAL_CI_SIZE	0x4000
+
+/* Map a physical portal window via the usdpaa fd */
+static int portal_mmap_phys(void **virt, uint64_t phys, size_t size)
+{
+	void *addr;
+
+	addr = mmap(NULL, size, PROT_READ | PROT_WRITE, MAP_SHARED,
+		    fd, (off_t)phys);
+	if (addr == MAP_FAILED) {
+		perror("mmap(portal)");
+		return -errno;
+	}
+
+	*virt = addr;
+	return 0;
+}
+
 int process_portal_map(struct dpaa_ioctl_portal_map *params)
 {
 	int ret = check_fd();
@@ -145,6 +177,31 @@
 		perror("ioctl(DPAA_IOCTL_PORTAL_MAP)");
 		return ret;
 	}
+
+	/*
+	 * Mainline kernel returns physical addresses in addr.cena/cinh.
+	 * Map them into this process via the usdpaa fd's mmap handler.
+	 */
+	ret = portal_mmap_phys(&params->addr.cena,
+		       (uint64_t)(uintptr_t)params->addr.cena,
+		       DPAA_PORTAL_CE_SIZE);
+	if (ret) {
+		fprintf(stderr, "portal CE mmap failed: phys=0x%llx\n",
+			(unsigned long long)(uintptr_t)params->addr.cena);
+		return ret;
+	}
+
+	ret = portal_mmap_phys(&params->addr.cinh,
+		       (uint64_t)(uintptr_t)params->addr.cinh,
+		       DPAA_PORTAL_CI_SIZE);
+	if (ret) {
+		fprintf(stderr, "portal CI mmap failed: phys=0x%llx\n",
+			(unsigned long long)(uintptr_t)params->addr.cinh);
+		munmap(params->addr.cena, DPAA_PORTAL_CE_SIZE);
+		params->addr.cena = NULL;
+		return ret;
+	}
+
 	return 0;
 }
 
