+/*
+ * Portal window sizes for QBMan portals on LS1046A.
+ * These are platform constants from the device-tree reg properties:
+ *   bman-portal: reg = <0x0 0x4000>, <0x4000000 0x4000>
+ *   qman-portal: reg = <0x0 0x4000>, <0x4000000 0x4000>
+ * CE (cache-enabled)  = 16KB (0x4000) — verified from running DTS
+ * CI (cache-inhibited) = 16KB (0x4000)
+ *
+ * CRITICAL: LS1046A has 16KB portals, NOT 64KB. The kernel mmap
+ * handler checks len <= pr->size_ce; requesting 0x10000 when the
+ * portal is only 0x4000 returns EINVAL.
+ *
+ * On mainline kernels, the PORTAL_MAP ioctl returns physical addresses
+ * instead of virtual addresses (do_mmap from ioctl context is unsafe).
+ * DPDK must mmap() the portal windows explicitly via the usdpaa fd.
+ * The kernel's usdpaa_mmap() handler sets correct page protection:
+ *   CE: Write-Back Non-Shareable (QBMan stashing protocol)
+ *   CI: Strongly-Ordered / Device-nGnRnE (portal doorbells)
+ */
+#define DPAA_PORTAL_CE_SIZE	0x4000   /* 16KB — from LS1046A DTS reg */
+#define DPAA_PORTAL_CI_SIZE	0x4000   /* 16KB — from LS1046A DTS reg */
+
+static int portal_mmap_phys(void **virt, uint64_t phys, size_t size);
+
 int process_portal_map(struct dpaa_ioctl_portal_map *params)
 {
 	int ret = check_fd();
@@ -137,9 +159,49 @@
 		perror("ioctl(DPAA_IOCTL_PORTAL_MAP)");
 		return ret;
 	}
+
+	/*
+	 * Mainline kernel returns physical addresses in addr.cena/cinh.
+	 * Map them into this process via the usdpaa fd's mmap handler
+	 * which applies correct page protection attributes (CE=WB-NS,
+	 * CI=Device-nGnRnE).
+	 */
+	ret = portal_mmap_phys(&params->addr.cena,
+			       (uint64_t)(uintptr_t)params->addr.cena,
+			       DPAA_PORTAL_CE_SIZE);
+	if (ret) {
+		fprintf(stderr, "portal CE mmap failed: phys=0x%llx\n",
+			(unsigned long long)(uintptr_t)params->addr.cena);
+		return ret;
+	}
+
+	ret = portal_mmap_phys(&params->addr.cinh,
+			       (uint64_t)(uintptr_t)params->addr.cinh,
+			       DPAA_PORTAL_CI_SIZE);
+	if (ret) {
+		fprintf(stderr, "portal CI mmap failed: phys=0x%llx\n",
+			(unsigned long long)(uintptr_t)params->addr.cinh);
+		/* Unmap CE on CI failure */
+		munmap(params->addr.cena, DPAA_PORTAL_CE_SIZE);
+		params->addr.cena = NULL;
+		return ret;
+	}
+
 	return 0;
 }
 
+/* Map a physical portal window via the usdpaa fd */
+static int portal_mmap_phys(void **virt, uint64_t phys, size_t size)
+{
+	void *addr;
+
+	addr = mmap(NULL, size, PROT_READ | PROT_WRITE, MAP_SHARED,
+		    fd, (off_t)phys);
+	if (addr == MAP_FAILED) {
+		perror("mmap(portal)");
+		return -errno;
+	}
+
+	*virt = addr;
+	return 0;
+}
